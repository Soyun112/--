# =============================================================================
# 사용법
#   1) 이 파일을 복사한 뒤 이름을 `.env` 로 바꿉니다.
#      (예: .env.example → .env  /  또는 파일명에서 "example"만 삭제)
#   2) 아래 [API 키] 칸에 발급받은 값을 붙여넣습니다.
#   3) 키가 비어 있으면 해당 기능은 자동으로 MOCK(샘플) 모드로 동작합니다.
#   4) `.env` 는 Git에 올리지 마세요. (이미 .gitignore 에 포함되어 있습니다)
# =============================================================================


# -----------------------------------------------------------------------------
# [API 키] — 여기에만 입력하면 됩니다
# -----------------------------------------------------------------------------

# 1) Tmap 보행자 길찾기 + POI 검색 (SK Open API)
#    발급: https://openapi.sk.com
#    사용: 도보 경로 후보, 지오코딩 폴백
TMAP_APP_KEY=

# 2) 공공데이터포털 (data.go.kr)
#    발급: https://www.data.go.kr → 마이페이지 → 인증키
#    사용: 어린이보호구역, 교통사고다발지역, 안심지킴이집, 보안등, 단속카메라
DATA_GO_KR_SERVICE_KEY=

# 3) Upstage (Document Parse / Information Extract / Solar LLM)
#    발급: https://console.upstage.ai
#    사용: 안전 문서 파싱·추출, 부모용/아이용 AI 설명
UPSTAGE_API_KEY=

# 4) 카카오 로컬 REST (건물·상호·역 이름 → 좌표)
#    발급: https://developers.kakao.com
#    사용: 출발지/목적지 지오코딩 (없으면 네이버/Tmap/내장사전으로 폴백)
KAKAO_REST_API_KEY=

# 5) 네이버 검색 API — 지역 검색 (지도 SDK 키와 다름)
#    발급: https://developers.naver.com
#    사용: 지오코딩 폴백, 경로 주변 랜드마크
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# 6) 기상청 초단기실황 (선택)
#    발급: data.go.kr 기상청 API (비우면 DATA_GO_KR_SERVICE_KEY 를 재사용)
#    사용: 날씨 맥락(비/눈 등) 반영
KMA_SERVICE_KEY=


# -----------------------------------------------------------------------------
# [동작 옵션] — 보통 기본값 그대로 두면 됩니다
# -----------------------------------------------------------------------------

# true/false 로 전체 MOCK 강제. 비우면 키 유무에 따라 자동 판단.
# MOCK_MODE=true

# 공공데이터 표준 API는 전국 단위라 데모 좌표와 안 맞을 수 있음.
# true(권장): 샘플 데이터 사용 / false: 실제 data.go.kr 호출
PUBLIC_DATA_MOCK=true

# 데모 기준 좌표 (샘플 데이터 중심점)
DEMO_CENTER_LAT=37.5013
DEMO_CENTER_LNG=127.0396

# SQLite 경로 (백엔드 기준 상대경로)
DATABASE_PATH=./app/data/safety.db

# 보안/디버그 (필요 시 주석 해제)
# TMAP_DEBUG_LOGGING=true
# DOCUMENT_INGEST_ENABLED=true
# ENABLE_OPENAPI_DOCS=true
# CORS_ORIGINS=https://your-project.vercel.app
