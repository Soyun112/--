# Tmap 보행자 길찾기 API (SK Open API, https://openapi.sk.com)
TMAP_APP_KEY=

# 공공데이터포털 서비스키 (data.go.kr, 어린이보호구역/교통사고다발지역)
DATA_GO_KR_SERVICE_KEY=

# Upstage API 키 (Document Parse / Information Extract / Solar LLM)
UPSTAGE_API_KEY=

# 건물명/역이름 -> 좌표 지오코딩용 키 (없으면 Tmap POI + 내장 사전으로 폴백)
KAKAO_REST_API_KEY=
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# 기상청 초단기실황 키. 비워두면 DATA_GO_KR_SERVICE_KEY를 재사용한다.
KMA_SERVICE_KEY=

# 값이 비어 있으면 자동으로 MOCK 모드로 동작합니다. true/false로 강제 지정 가능.
# MOCK_MODE=true

# 아동안전지킴이집/보안등/무인단속카메라는 지역 필터가 없는 전국 단위 API라 서비스키가
# 있어도 데모 좌표와 무관한 페이지가 조회될 수 있음. true(기본 권장)면 항상 샘플 데이터로
# 데모 좌표에 맞는 결과를 보여준다. false면 실제 data.go.kr 데이터를 그대로 사용.
PUBLIC_DATA_MOCK=true

# 안전점수 계산 시 사용할 데모 기준 좌표 (샘플 데이터 중심점)
DEMO_CENTER_LAT=37.5013
DEMO_CENTER_LNG=127.0396

# SQLite 파일 경로
DATABASE_PATH=./app/data/safety.db
