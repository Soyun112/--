# =============================================================================
# 사용법
#   1) 이 파일을 복사한 뒤 이름을 `.env` 로 바꿉니다.
#      (예: .env.example → .env  /  또는 파일명에서 "example"만 삭제)
#   2) 아래 [API 키] 칸에 발급받은 값을 붙여넣습니다.
#   3) 키가 비어 있으면 해당 기능은 자동으로 MOCK(샘플) 모드로 동작합니다.
#   4) `.env` 는 Git에 올리지 마세요. (이미 .gitignore 에 포함되어 있습니다)
# =============================================================================


# -----------------------------------------------------------------------------
# [API 키] — 여기에만 입력하면 됩니다
# -----------------------------------------------------------------------------

# 1) Tmap 보행자 길찾기 + POI 검색 (SK Open API)
#    발급: https://openapi.sk.com
#    사용: 도보 경로 후보, 지오코딩 폴백
TMAP_APP_KEY=
# 보행자 searchOption: 0=추천, 4=추천+대로우선(기본), 10=최단, 30=최단+계단제외
TMAP_PEDESTRIAN_SEARCH_OPTION=4
# 긴 직선 구간을 구간별 Tmap 재탐색으로 촘촘히 만듦 (API 많이 씀, 기본 false)
TMAP_ROUTE_DENSIFY_ENABLED=false
TMAP_ROUTE_DENSIFY_MIN_LEG_M=25
# Road API(matchToRoads): 차량 도로망 스냅 — 보행 통학로에는 기본 비활성
TMAP_ROAD_MATCH_ENABLED=false
# 대안 보행 경로 추가 조회 (API +1)
TMAP_PEDESTRIAN_ALT_ENABLED=true
# Tmap Free 티어 일일 한도 (SK Open API 기준, 서버 메모리 카운터)
TMAP_DAILY_LIMIT_ROUTE=1000
TMAP_DAILY_LIMIT_ROAD=1000
TMAP_DAILY_LIMIT_POI=20000
TMAP_DAILY_LIMIT_GEOCODE=20000
# 한도 근접 시 여유분(건) — 이 값만큼 남기면 API 호출 중단
TMAP_DAILY_RESERVE_ROUTE=20
TMAP_DAILY_RESERVE_ROAD=20
# 동일 출발·도착 경로/지오코딩 캐시 TTL(초)
TMAP_CACHE_TTL_ROUTE_S=21600
TMAP_CACHE_TTL_GEOCODE_S=86400
# Road API는 좌표가 이 개수 미만일 때만 1회 호출 (ENABLED=true일 때만)
TMAP_ROAD_MATCH_MIN_COORDS=30

# 2) 공공데이터포털 (data.go.kr)
#    발급: https://www.data.go.kr → 마이페이지 → 인증키
#    사용: 어린이보호구역, 교통사고다발지역, 안심지킴이집, 보안등, 단속카메라
DATA_GO_KR_SERVICE_KEY=

# 3) Upstage (Document Parse / Information Extract / Solar LLM)
#    발급: https://console.upstage.ai
#    사용: 안전 문서 파싱·추출, 부모용/아이용 AI 설명
UPSTAGE_API_KEY=

# 3-1) Liner Search API (주변 안전문서 웹 검색)
#    발급: https://platform.liner.com
#    사용: 지역명 기반 공사·통행제한 공고 검색 (백엔드 프록시만 사용, 프론트 노출 금지)
LINER_API_KEY=

# 4) 카카오 로컬 REST (건물·상호·역 이름 → 좌표)
#    발급: https://developers.kakao.com
#    사용: 출발지/목적지 지오코딩 (없으면 네이버/Tmap/내장사전으로 폴백)
KAKAO_REST_API_KEY=

# 5) 네이버 검색 API — 지역 검색 (지도 SDK 키와 다름)
#    발급: https://developers.naver.com
#    사용: 지오코딩 폴백, 경로 주변 랜드마크
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# 6) 기상청 초단기실황 (선택)
#    발급: data.go.kr 기상청 API (비우면 DATA_GO_KR_SERVICE_KEY 를 재사용)
#    사용: 날씨 맥락(비/눈 등) 반영
KMA_SERVICE_KEY=


# -----------------------------------------------------------------------------
# [동작 옵션] — 보통 기본값 그대로 두면 됩니다
# -----------------------------------------------------------------------------

# true/false 로 전체 MOCK 강제. 비우면 키 유무에 따라 자동 판단.
# MOCK_MODE=true

# 공공데이터 표준 API는 전국 단위라 데모 좌표와 안 맞을 수 있음.
# true(권장): 샘플 데이터 사용 / false: 실제 data.go.kr 호출
PUBLIC_DATA_MOCK=true

# 데모 기준 좌표 (샘플 데이터 중심점)
DEMO_CENTER_LAT=37.5013
DEMO_CENTER_LNG=127.0396

# SQLite 경로 (백엔드 기준 상대경로)
DATABASE_PATH=./app/data/safety.db

# 보안/디버그 (필요 시 주석 해제)
# 문서 업로드·파싱 API (기본 켜짐). 끄려면 false
# DOCUMENT_INGEST_ENABLED=false
# ENABLE_OPENAPI_DOCS=true
# CORS_ORIGINS=https://your-project.vercel.app


# -----------------------------------------------------------------------------
# [Google OAuth] — Render / 로컬 .env (Secret은 Git에 넣지 마세요)
# -----------------------------------------------------------------------------
# Google Cloud Console → OAuth 클라이언트 (웹)
GOOGLE_CLIENT_ID=217588693336-ujkctcnrd4o017tjkfnrl322ou29dgdt.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# 백엔드 OAuth 콜백 (Google Console "승인된 리디렉션 URI"와 동일)
# 로컬: http://127.0.0.1:8000/api/auth/google/callback
# Render: https://kids-safe-route-api.onrender.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=https://kids-safe-route-api.onrender.com/api/auth/google/callback

# JWT 서명용 (임의의 긴 랜덤 문자열, 예: openssl rand -hex 32)
JWT_SECRET=

# 로그인 유지 시간(시간). 기본 168 = 7일
# JWT_EXPIRE_HOURS=168

# 로그인 후 돌아갈 프론트 (배포)
FRONTEND_URL=https://kids-abcd.vercel.app

# 추가 허용 프론트 origin (쉼표 구분, 선택)
# ALLOWED_FRONTEND_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
